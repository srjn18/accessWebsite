---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import { Image } from "astro:assets";

/* Astronaut */
import astronaut from "../assets/developers/astronaut.png";

/* Developers */
import dev1 from "../assets/developers/developer1.jpg";
import dev2 from "../assets/developers/developer2.jpg";
import dev3 from "../assets/developers/developer3.jpg";
import dev4 from "../assets/developers/developer4.jpg";
import dev5 from "../assets/developers/developer5.jpg";

/* Flip images */
import flip1 from "../assets/developers/flip1.jpg";
import flip2 from "../assets/developers/flip2.jpeg";
import flip3 from "../assets/developers/flip3.jpg";
import flip4 from "../assets/developers/flip4.jpg";
import flip5 from "../assets/developers/flip5.jpg";
---

<Layout>
  <Navbar />

  <div class="aurora-ribbon aurora-1"></div>
  <div class="aurora-ribbon aurora-2"></div>
  <div class="aurora-ribbon aurora-3"></div>

  <!-- Astronaut -->
  <Image
    src={astronaut}
    alt="Astronaut Floating"
    class="astro"
    loading="eager"
  />

  <canvas id="starCanvas"></canvas>

  <header>
    <h3><span class="page-title">Meet the Dev Team</span></h3>
  </header>

  <div class="team-container">
    <div class="team-row">

      <!-- Developer 1 -->
      <div class="team-member">
        <div class="card">
          <div class="front">
            <Image src={dev1} alt="Soham Misra" />
          </div>
          <div class="back">
            <Image src={flip1} alt="Flip image 1" />
          </div>
        </div>
        <div class="overlay">
          <h3>Soham Misra</h3>
          <p>"Hare Krishna"</p>
          <div class="social-icons">
            <a href="https://github.com/SohamMisra" target="_blank"><i class="fab fa-github"></i></a>
            <a href="https://in.linkedin.com/in/soham-misra135" target="_blank"><i class="fab fa-linkedin"></i></a>
            <a href="https://www.instagram.com/krishna_sohamisra/" target="_blank"><i class="fab fa-instagram"></i></a>
          </div>
        </div>
      </div>

      <!-- Developer 2 -->
      <div class="team-member">
        <div class="card">
          <div class="front">
            <Image src={dev2} alt="Gurudutt R Pai" />
          </div>
          <div class="back">
            <Image src={flip2} alt="Flip image 2" />
          </div>
        </div>
        <div class="overlay">
          <h3>Gurudutt R Pai</h3>
          <p>Twilio, Finacle & HPE Cracked...</p>
          <div class="social-icons">
            <a href="https://github.com/GuruduttRPai" target="_blank"><i class="fab fa-github"></i></a>
            <a href="https://in.linkedin.com/in/gurudutt-r-pai-09551124b" target="_blank"><i class="fab fa-linkedin"></i></a>
            <a href="https://www.instagram.com/gurudutt_r_pai_/" target="_blank"><i class="fab fa-instagram"></i></a>
          </div>
        </div>
      </div>

      <!-- Developer 3 -->
      <div class="team-member">
        <div class="card">
          <div class="front">
            <Image src={dev3} alt="Anirudh Pai" />
          </div>
          <div class="back">
            <Image src={flip3} alt="Flip image 3" />
          </div>
        </div>
        <div class="overlay">
          <h3>Anirudh Pai</h3>
          <p>"Sometimes one needs a little bit of Faith when faced with Difficulty."</p>
          <div class="social-icons">
            <a href="https://github.com/AnirudhPai13" target="_blank"><i class="fab fa-github"></i></a>
            <a href="https://in.linkedin.com/in/anirudh-pai-296714291" target="_blank"><i class="fab fa-linkedin"></i></a>
            <a href="https://www.instagram.com/paiboi_398/" target="_blank"><i class="fab fa-instagram"></i></a>
          </div>
        </div>
      </div>

      <!-- Developer 4 -->
      <div class="team-member">
        <div class="card">
          <div class="front">
            <Image src={dev4} alt="Yajnesh Kumar" />
          </div>
          <div class="back">
            <Image src={flip4} alt="Flip image 4" />
          </div>
        </div>
        <div class="overlay">
          <h3>Yajnesh Kumar</h3>
          <p>SELECT * FROM life WHERE success = 'hardwork' AND regret = NULL;</p>
          <div class="social-icons">
            <a href="https://github.com/YajneshKumar2004" target="_blank"><i class="fab fa-github"></i></a>
            <a href="https://in.linkedin.com/in/yajneshkumar2004" target="_blank"><i class="fab fa-linkedin"></i></a>
            <a href="https://www.instagram.com/kulal_.2004/" target="_blank"><i class="fab fa-instagram"></i></a>
          </div>
        </div>
      </div>

      <!-- Developer 5 -->
      <div class="team-member">
        <div class="card">
          <div class="front">
            <Image src={dev5} alt="Vaishnavi K S" />
          </div>
          <div class="back">
            <Image src={flip5} alt="Flip image 5" />
          </div>
        </div>
        <div class="overlay">
          <h3>Vaishnavi K S</h3>
          <p>There’s a lot of beauty in ordinary things. Isn’t that the whole point?</p>
          <div class="social-icons">
            <a href="https://github.com/2vaishnavi-ks" target="_blank"><i class="fab fa-github"></i></a>
            <a href="https://www.linkedin.com/in/vaishnavi-k-s-57b13a28b/" target="_blank"><i class="fab fa-linkedin"></i></a>
            <a href="https://www.instagram.com/vaish_ks_/" target="_blank"><i class="fab fa-instagram"></i></a>
          </div>
        </div>
      </div>

    </div>
  </div>

  <script>
    const astro = document.querySelector(".astro") as HTMLElement;

    function moveAstronaut() {
      if (!astro) return;
      const maxX = window.innerWidth - 170;
      const maxY = window.innerHeight - 170;
      astro.style.transition = `transform ${(Math.random() * 5 + 5)}s ease-in-out`;
      astro.style.transform = `translate(${Math.random() * maxX}px, ${Math.random() * maxY}px)`;
    }

    setInterval(moveAstronaut, 6000);
    moveAstronaut();
  </script>

  <script src="/stars.js" is:inline defer></script>
</Layout>

<style>
/* Responsive safety additions */
img {
  max-width: 100%;
  height: auto;
}
    /* Header styles */
header {
    padding: 15px 20px;
    margin-bottom: 10px;
    text-align: center;
}

header h3 {
    margin: 0;
    font-weight: 700;
    text-shadow: 0 0 10px rgba(0, 0, 0, 0.5);
}

.page-title {
    font-size: 42px;
    font-weight: bold;
    color: whitesmoke;
    position: relative;
    display: inline-block;
    margin-bottom: 5px;
    margin-top: 110px;
}

.page-title::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 3px;
    background: linear-gradient(90deg, #441069, #00c8ff99);
    border-radius: 2px;
    margin-top: 25px;
}

/* Team container */
.team-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 10px 20px;
    max-width: 1200px;
    margin: 0 auto;
}

.team-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    width: 100%;
    max-width: 1200px;
}

/* Team member cards */
.team-member {
    position: relative;
    width: 100%;
    max-width: 280px;
    height: 450px;
    perspective: 1500px;
    margin: 0 auto;
}

/* Card container */
.card {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    border-radius: 15px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
}

.team-member:hover .card {
    transform: rotateY(180deg);
}

/* Card faces */
.front, .back {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 15px;
    backface-visibility: hidden;
    overflow: hidden;
}

.front::before, .back::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent 70%, rgba(0, 0, 0, 0.8));
    z-index: 1;
}

.front img, .back img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
}

.team-member:hover .front img, 
.team-member:hover .back img {
    transform: scale(1.05);
}

.back {
    transform: rotateY(180deg);
}

/* Info overlay */
.overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(5px);
    width: 100%;
    padding: 15px 12px;
    border-radius: 0 0 15px 15px;
    z-index: 2;
    transition: all 0.4s ease;
    box-sizing: border-box;
    min-height: 120px;
}

.team-member:hover .overlay {
    background: rgba(0, 0, 0, 0.85);
}

.overlay h3 {
    font-size: 20px;
    margin: 0 0 8px;
    color: #fff;
    font-weight: 600;
}

.overlay p {
    font-size: 15px;
    margin: 0 0 12px;
    opacity: 0.9;
    color: #e0e0e0;
    font-style: italic;
    line-height: 1.3;
    max-height: 60px;
    overflow: visible;
    white-space: normal;
}

/* Astronaut animation */
.astro {
  position: absolute;
  top: 200px;     /* adjust as needed */
  left: 50px;   /* start off-screen */
  width: 180px;
  overflow: hidden;
  pointer-events: none;
  z-index: 1;

  /*animation: fly-across 20s linear infinite,
             float 4s ease-in-out infinite,
             tilt 6s ease-in-out infinite;*/
}

/*@keyframes fly-across {
  from { left: -200px; }
  to   { left: 110%; } /* goes off right side 
}

@keyframes float {
  0%   { transform: translateY(0px); }
  50%  { transform: translateY(-15px); }
  100% { transform: translateY(0px); }
}

@keyframes tilt {
  0%   { transform: rotate(0deg); }
  50%  { transform: rotate(-4deg); }
  100% { transform: rotate(0deg); }
}*/



/* Social icons */
/* Update the social-links class to ensure proper centering */
.social-links {
    margin-bottom: 15px;
    display: flex;
    justify-content: center;
    align-items: center;
    color: #fff;
    gap: 20px; /* Creates consistent spacing between the icons */
}

.social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    transition: all 0.3s ease;
    font-size: 18px;
    color: #fff;
    margin: 0;
}

.social-links a:hover {
    background: #f0ecf3;
    transform: translateY(-3px);
}

/* Responsive design */
@media (max-width: 1024px) {
    .team-row {
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        max-width: 600px;
    }
}

@media (max-width: 768px) {
    .team-row {
        grid-template-columns: 1fr;
        gap: 15px;
        max-width: 320px;
    }
    
    .team-member {
        height: 300px;
        margin-bottom: 10px;
    }
    
    .page-title {
        font-size: 36px;
    }
    
    .team-container {
        padding: 10px 15px 30px 15px;
    }
}

@media (max-width: 480px) {
    .team-container {
        padding: 5px 15px 40px 15px;
    }
    
    .team-member {
        height: 280px;
    }
    
    .page-title {
        font-size: 28px;
    }
    
    .overlay h3 {
        font-size: 18px;
    }
}

/* Animation for the cards */
@keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

.team-member {
    animation: fadeIn 0.5s ease-out forwards;
    opacity: 0;
}

.team-member:nth-child(1) { animation-delay: 0.1s; }
.team-member:nth-child(2) { animation-delay: 0.3s; }
.team-member:nth-child(3) { animation-delay: 0.5s; }
.team-member:nth-child(4) { animation-delay: 0.7s; }
.team-member:nth-child(5) { animation-delay: 0.9s; }

</style>