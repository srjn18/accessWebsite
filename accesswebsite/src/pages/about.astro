---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
//import AccessForceEffect from "../components/accessLogo.astro";
import accessLogo from "../assets/homePages/accesslogo.png";
import image1 from "../assets/about_us_images/image_1.jpeg";
import image2 from "../assets/about_us_images/image_2.jpg";
import image3 from "../assets/about_us_images/image_3.JPG";
import image4 from "../assets/about_us_images/image_4.JPG";
import image5 from "../assets/about_us_images/image_5.JPG";
import image6 from "../assets/about_us_images/image_6.JPG";
import image7 from "../assets/about_us_images/image_7.JPG";
import image8 from "../assets/about_us_images/image_8.jpg";
import "../styles/about.css";
---

<Navbar />

<Layout>
  <div class="aurora-ribbon aurora-1"></div>
  <div class="aurora-ribbon aurora-2"></div>
  <div class="aurora-ribbon aurora-3"></div>

  <canvas id="starCanvas"></canvas>

  <div class="page-container">
    <section id="hero-intro" style="padding:120px 20px 80px 20px;text-align:center;">
      <div style="max-width:900px;margin:0 auto;">
        <!-- Image Container -->
        <div style="margin-bottom:40px;">
          <img src={accessLogo.src} alt="ACCESS Logo" style="max-width:100%;height:auto;border-radius:12px;"/>
        </div>
        
        <!-- Typewriter Text -->
        <h1 class="typewriter" style="font-size:clamp(2rem, 5vw, 3.5rem);color:#ffffff;margin:0;font-weight:800;letter-spacing:-0.02em;">Where Code Meets Connectivity</h1>
      </div>
    </section>

    <section id="committee" style="padding:60px 20px;">
      <div style="max-width:1100px;margin:0 auto;">
        <div style="display:flex;gap:30px;align-items:center;justify-content:space-between;flex-wrap:wrap;">
          <div style="flex:1;min-width:320px;">
            <div class="vm-card" style="padding:30px;border-radius:12px;">
              <h2 style="margin:0 0 10px 0;text-align:center;font-size:1.8rem;">The ACCESS Committee</h2>
              <h3 style="margin:0 0 18px 0;color:rgba(255,255,255,0.95);text-align:center;">ACCESS stands for the Association of Computer and Communication Engineering Students</h3>
              <p style="color:rgba(209,209,209,0.95);line-height:1.7;margin:0;text-align:center;">It is the official student branch association of our department and plays a significant role in organizing various events and activities that contribute to the growth and development of students while also supporting the department in multiple ways.</p>
            </div>
          </div>

          <div style="flex:1;min-width:320px;">
            <div class="carousel-container" style="position:relative;overflow:hidden;border-radius:12px;aspect-ratio:4/3;background:#1a1a1a;">
              <div class="carousel-wrapper" style="display:flex;height:100%;transition:transform 0.6s ease-in-out;">
                <img class="carousel-image" src={image1.src} alt="image_1" style="min-width:100%;height:100%;object-fit:cover;" />
                <img class="carousel-image" src={image2.src} alt="image_2" style="min-width:100%;height:100%;object-fit:cover;" />
                <img class="carousel-image" src={image3.src} alt="image_3" style="min-width:100%;height:100%;object-fit:cover;" />
                <img class="carousel-image" src={image4.src} alt="image_4" style="min-width:100%;height:100%;object-fit:cover;" />
                <img class="carousel-image" src={image5.src} alt="image_5" style="min-width:100%;height:100%;object-fit:cover;" />
                <img class="carousel-image" src={image6.src} alt="image_6" style="min-width:100%;height:100%;object-fit:cover;" />
                <img class="carousel-image" src={image7.src} alt="image_7" style="min-width:100%;height:100%;object-fit:cover;" />
                <img class="carousel-image" src={image8.src} alt="image_8" style="min-width:100%;height:100%;object-fit:cover;" />
              </div>
              
              <!-- Navigation Dots -->
              <div class="carousel-dots" style="position:absolute;bottom:16px;left:50%;transform:translateX(-50%);display:flex;gap:8px;">
                <span class="dot active" data-index="0" style="width:10px;height:10px;border-radius:50%;background:#ffffff;cursor:pointer;transition:0.3s;"></span>
                <span class="dot" data-index="1" style="width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,0.5);cursor:pointer;transition:0.3s;"></span>
                <span class="dot" data-index="2" style="width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,0.5);cursor:pointer;transition:0.3s;"></span>
                <span class="dot" data-index="3" style="width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,0.5);cursor:pointer;transition:0.3s;"></span>
                <span class="dot" data-index="4" style="width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,0.5);cursor:pointer;transition:0.3s;"></span>
                <span class="dot" data-index="5" style="width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,0.5);cursor:pointer;transition:0.3s;"></span>
                <span class="dot" data-index="6" style="width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,0.5);cursor:pointer;transition:0.3s;"></span>
                <span class="dot" data-index="7" style="width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,0.5);cursor:pointer;transition:0.3s;"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="coordinators" style="padding:30px 20px;">
      <div style="max-width:1100px;margin:0 auto;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:30px;align-items:stretch;">
          <div class="vm-card" style="padding:40px;border-radius:10px;">
            <h4 style="text-align:center;margin:6px 0 20px 0;color:rgba(255,255,255,0.9);letter-spacing:1px;font-size:1.3rem;">Placement Coordinator</h4>
            <p style="margin:0;color:rgba(209,209,209,0.95);line-height:1.8;text-align:justify;font-size:1rem;">Dear Students,
I am pleased to announce that the Abhyudaya Placement Department at NMAMIT is dedicated to bridging the gap between students and industry. The department focuses on preparing students for successful careers by facilitating placement opportunities, organizing skill development sessions, and conducting mock interviews. It partners with leading companies to ensure diverse job opportunities for graduates.</p>
            <button class="read-more-btn" onclick="openModal('placement-modal')" style="margin-top:20px;display:block;margin-left:auto;margin-right:auto;padding:10px 24px;background:#e8eaea;color:#020203;border:none;border-radius:6px;font-weight:600;cursor:pointer;font-size:0.95rem;transition:0.3s;">Read More</button>
          </div>

          <div class="vm-card" style="padding:40px;border-radius:10px;">
            <h4 style="text-align:center;margin:6px 0 20px 0;color:rgba(255,255,255,0.9);letter-spacing:1px;font-size:1.3rem;">Student Coordinators Message</h4>
            <p style="margin:0;color:rgba(209,209,209,0.95);line-height:1.8;text-align:justify;font-size:1rem;">I am thrilled to serve as ACCESS Coordinator again. This is my 4th tenure, and I am proud of what we have achieved. ACCESS helps students gain confidence, leadership, and teamwork skills. I urge you to join and make the most of it. Thanks to students, colleagues, HOD, and Principal for their trust. Let's keep making ACCESS thrive!</p>
            <button class="read-more-btn" onclick="openModal('student-modal')" style="margin-top:20px;display:block;margin-left:auto;margin-right:auto;padding:10px 24px;background:#e8eaea;color:#020203;border:none;border-radius:6px;font-weight:600;cursor:pointer;font-size:0.95rem;transition:0.3s;">Read More</button>
          </div>
        </div>
      </div>
    </section>

    <!-- MODALS -->
    <div id="placement-modal" class="modal" style="display:none;">
      <div class="modal-backdrop" onclick="closeModal('placement-modal')"></div>
      <div class="modal-content">
        <h2 style="margin-top:0;color:#ffffff;text-align:center;">Placement Coordinator</h2>
        <p style="color:rgba(209,209,209,0.95);line-height:1.8;text-align:justify;font-size:1rem;">Dear Students,
<br /><br />
I am pleased to announce that the Abhyudaya Placement Department at NMAMIT is dedicated to bridging the gap between students and industry. The department focuses on preparing students for successful careers by facilitating placement opportunities, organizing skill development sessions, and conducting mock interviews. It partners with leading companies to ensure diverse job opportunities for graduates.
<br /><br />
Our department's placement drive for this academic year (2025–26) has been a tremendous success. Several prestigious companies have visited the campus, offering exciting job opportunities to our talented students. Notable recruiters include Nutanix, Oracle, Infosys, Cognizant, Sasken Technologies, IBM, LTI Mindtree, Tismo, Sony India, Cohesity, Wipfli India, Black Duck Software, DevRev, Capillary, Cloverbay Technologies. International placement opportunities were also provided by companies such as Nidec Machine Tools (Japan), Matsuura Machinery Corp. (Japan), and Maruhide (Japan) and many others.
<br /><br />
I would like to extend my congratulations to all the students who have secured placements and those who are considering higher studies. Your hard work and dedication have paid off, and I am confident that you will excel in your respective roles.
<br /><br />
For those who are still exploring opportunities, please remain proactive and continue to engage with ongoing placement activities. Remember, placements are not just about securing a job but about finding a position that aligns with your career goals and aspirations. Stay focused, keep improving, and we are here to guide you every step of the way.
<br /><br />
Thank you
<br /><br />
Mr. Sandeep Kumar S<br />
Department of CCE,<br />
Placement Coordinator</p>
      </div>
    </div>

    <div id="student-modal" class="modal" style="display:none;">
      <div class="modal-backdrop" onclick="closeModal('student-modal')"></div>
      <div class="modal-content">
        <h2 style="margin-top:0;color:#ffffff;text-align:center;">Student Coordinators Message</h2>
        <p style="color:rgba(209,209,209,0.95);line-height:1.8;text-align:justify;font-size:1rem;">I am thrilled to serve as ACCESS Coordinator again. This is my 4th tenure, and I am proud of what we have achieved. ACCESS helps students gain confidence, leadership, and teamwork skills. I urge you to join and make the most of it. Thanks to students, colleagues, HOD, and Principal for their trust. Let's keep making ACCESS thrive!</p>
      </div>
    </div>

  </div> <!-- page-container -->

  <script is:inline>
    // Carousel functionality
    let currentSlide = 0;
    const totalSlides = 8;
    let carouselInterval;

    function moveCarousel(index) {
      currentSlide = index % totalSlides;
      const wrapper = document.querySelector('.carousel-wrapper');
      const offset = currentSlide * 100;
      wrapper.style.transform = `translateX(-${offset}%)`;
      updateDots();
    }

    function updateDots() {
      document.querySelectorAll('.dot').forEach((dot, index) => {
        if (index === currentSlide) {
          dot.style.background = '#ffffff';
        } else {
          dot.style.background = 'rgba(255,255,255,0.5)';
        }
      });
    }

    function autoRotate() {
      currentSlide = (currentSlide + 1) % totalSlides;
      const wrapper = document.querySelector('.carousel-wrapper');
      const offset = currentSlide * 100;
      wrapper.style.transform = `translateX(-${offset}%)`;
      updateDots();
    }

    // Initialize carousel
    window.addEventListener('DOMContentLoaded', function() {
      // Setup dot click handlers
      document.querySelectorAll('.dot').forEach(dot => {
        dot.addEventListener('click', function() {
          const index = parseInt(this.dataset.index);
          moveCarousel(index);
          clearInterval(carouselInterval);
          carouselInterval = setInterval(autoRotate, 2500);
        });
      });

      // Start auto-rotation (2500ms between images)
      carouselInterval = setInterval(autoRotate, 2500);
    });

    function openModal(modalId) {
      const modal = document.getElementById(modalId);
      if (modal) {
        modal.style.display = 'block';
        document.body.style.overflow = 'hidden';
      }
    }

    function closeModal(modalId) {
      const modal = document.getElementById(modalId);
      if (modal) {
        modal.style.display = 'none';
        document.body.style.overflow = 'auto';
      }
    }

    // Close modal when clicking outside the content
    window.addEventListener('click', function(event) {
      const placementModal = document.getElementById('placement-modal');
      const studentModal = document.getElementById('student-modal');
      
      if (placementModal && event.target === placementModal) {
        closeModal('placement-modal');
      }
      if (studentModal && event.target === studentModal) {
        closeModal('student-modal');
      }
    });

    // Close modal with Escape key
    document.addEventListener('keydown', function(event) {
      if (event.key === 'Escape') {
        closeModal('placement-modal');
        closeModal('student-modal');
      }
    });
  </script>

  <script src="/bento-animate.js" is:inline defer></script>

<script src="/stars.js" defer></script>
  <script src="/scroll-animations.js" is:inline defer></script>

</Layout>

<Footer />