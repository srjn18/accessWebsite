<script is:inline>

function toggleDetails(id) {

  const section = document.getElementById(id);

  if(!section) return;

  section.classList.toggle("hidden");

  if(!section.classList.contains("hidden")) {
    section.scrollIntoView({
      behavior:"smooth",
      block:"center"
    });
  }

}


/* Scroll Animation */

const observer = new IntersectionObserver(entries => {

  entries.forEach(entry => {

    if(entry.isIntersecting) {
      entry.target.classList.add("in-view");
    }

  });

},{ threshold:0.25 });


document.querySelectorAll(
".faculty-card, .faculty-details-wrapper, details"
).forEach(el => observer.observe(el));


</script>



<style>

body{
background:
radial-gradient(circle at 50% 50%, rgba(139,92,246,.35), transparent 45%),
radial-gradient(circle at 50% 50%, rgba(34,211,238,.3), transparent 65%),
linear-gradient(180deg,#020008,#070014,#010005);
background-attachment:fixed;
overflow-x:hidden;
}

/* HEADER */

.faculty-header{
margin-top:80px;
text-align:center;
color:#c4b5fd;
text-shadow:0 0 25px rgba(139,92,246,.9);
}

.faculty-header h1{
font-size:36px;
}

/* CONTAINER */

.faculty-container{
display:flex;
flex-wrap:wrap;
justify-content:center;
gap:60px;
margin:90px 40px;
}

/* CARD */

.faculty-card{
width:280px;
padding:25px;
background:rgba(20,20,45,.65);
backdrop-filter:blur(12px);
border-radius:25px;
text-align:center;
box-shadow:0 0 20px rgba(139,92,246,.6);
opacity:0;
transform:translateY(80px);
}

.faculty-card.in-view{
opacity:1;
transform:translateY(0);
transition:1s;
}

.photo-wrapper{
width:140px;
height:140px;
margin:auto;
border-radius:50%;
overflow:hidden;
}

.faculty-photo{
width:100%;
height:100%;
object-fit:cover;
}

/* DETAILS */

.faculty-details{
width:100%;
display:flex;
justify-content:center;
}

.faculty-details-wrapper{
width:100%;
max-width:820px;
padding:45px 35px;
background:rgba(15,18,45,.92);
border-radius:30px;
text-align:center;
box-shadow:0 0 80px rgba(139,92,246,.45);
}

.hidden{
display:none;
}

.faculty-photo-wrapper-large{
width:220px;
height:220px;
border-radius:50%;
overflow:hidden;
margin:auto;
}

.faculty-photo-large{
width:100%;
height:100%;
object-fit:cover;
}

details{
background:rgba(30,30,65,.75);
margin:12px 0;
padding:12px;
border-radius:14px;
}

details summary{
cursor:pointer;
}

/* BUTTON */

.glow{
margin-top:20px;
padding:10px 25px;
border-radius:30px;
border:none;
background:linear-gradient(45deg,#8b5cf6,#22d3ee);
color:#fff;
box-shadow:0 0 30px rgba(139,92,246,.8);
cursor:pointer;
transition:.3s;
}

.glow:hover{
transform:scale(1.1);
}

/* ================= RESPONSIVE ================= */

@media (max-width:1024px){

.faculty-container{
gap:40px;
margin:70px 30px;
}

.faculty-card{
width:240px;
}

}

@media (max-width:768px){

.faculty-header h1{
font-size:28px;
}

.faculty-container{
margin:60px 20px;
}

.faculty-card{
width:90%;
max-width:320px;
}

.photo-wrapper{
width:120px;
height:120px;
}

.faculty-photo-wrapper-large{
width:180px;
height:180px;
}

.faculty-details-wrapper{
padding:30px 20px;
}

}

@media (max-width:480px){

.faculty-header h1{
font-size:22px;
}

.faculty-container{
gap:30px;
margin:50px 10px;
}

.photo-wrapper{
width:100px;
height:100px;
}

.faculty-photo-wrapper-large{
width:150px;
height:150px;
}

.glow{
font-size:14px;
padding:8px 20px;
}

}

</style>

</Layout>
