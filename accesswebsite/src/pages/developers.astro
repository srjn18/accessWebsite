---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import { Image } from "astro:assets";

/* Assets */
import astronaut from "../assets/developers/astronaut.png";
import dev1 from "../assets/developers/developer1.jpg";
import dev2 from "../assets/developers/developer2.jpg";
import dev3 from "../assets/developers/developer3.jpg";
import dev4 from "../assets/developers/developer4.jpg";
import dev5 from "../assets/developers/developer5.jpg";
import git from "../assets/icons/github.svg";

const team = [
  { name: "Soham Misra", quote: "Hare Krishna", img: dev1, github: "SohamMisra", linkedin: "soham-misra135", insta: "krishna_sohamisra" },
  { name: "Gurudutt R Pai", quote: "Twilio, Finacle & HPE Cracked...", img: dev2, github: "GuruduttRPai", linkedin: "gurudutt-r-pai-09551124b", insta: "gurudutt_r_pai_" },
  { name: "Anirudh Pai", quote: "Faith over Difficulty.", img: dev3, github: "AnirudhPai13", linkedin: "anirudh-pai-296714291", insta: "paiboi_398" },
  { name: "Yajnesh Kumar", quote: "SELECT * FROM life...", img: dev4, github: "YajneshKumar2004", linkedin: "yajneshkumar2004", insta: "kulal_.2004" },
  { name: "Vaishnavi K S", quote: "There's a lot of beauty in ordinary things. Isn't that the whole point?", img: dev5, github: "2vaishnavi-ks", linkedin: "vaishnavi-k-s-57b13a28b", insta: "vaish_ks_" },
];
---

<Layout title="Meet the Dev Team">
  <Navbar />

  <div class="prison-wall">
    <div class="grid-layer"></div>
    <div class="height-markers"></div>
  </div>

  <div class="character-space">
    <Image 
      src={astronaut} 
      alt="Astronaut floating in space" 
      class="drifting-char" 
      loading="eager" 
    />
  </div>

  <main class="content-wrapper">
    <header>
      <h1 class="page-title">The Dev Team</h1>
    </header>

    <div class="team-grid">
      {team.map((member) => (
        <div class="member-card">
          <div class="image-box">
            <Image 
              src={member.img} 
              alt={`Portrait of ${member.name}`} 
              loading="eager" 
            />
          </div>
          <div class="info-overlay">
            <h3>{member.name}</h3>
            <p>"{member.quote}"</p>
            <div class="social-links">
              <a href={`https://github.com/${member.github}`} target="_blank" aria-label={`${member.name}'s GitHub`}>
                <img src="/images/icons/github.svg" alt="Github" />
              </a>
              <a href={`https://linkedin.com/in/${member.linkedin}`} target="_blank" aria-label={`${member.name}'s LinkedIn`}>
                <img src="/images/icons/linkedin.svg" alt="LinkedIn" />
              </a>
              <a href={`https://instagram.com/${member.insta}`} target="_blank" aria-label={`${member.name}'s Instagram`}>
                <img src="/images/icons/instagram.svg" alt="Instagram" />
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </main>
</Layout>

<style>
  /* Fix: Background Lines */
  .prison-wall {
    position: fixed;
    inset: 0;
    background: #080a0c;
    z-index: -1;
    overflow: hidden;
  }

  .grid-layer {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(0, 242, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 242, 255, 0.05) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  .height-markers {
    position: absolute;
    width: 100%;
    height: 1000%; /* Long height for infinite scroll */
    background: repeating-linear-gradient(
      transparent,
      transparent 120px,
      rgba(0, 242, 255, 0.2) 120px,
      rgba(0, 242, 255, 0.2) 122px
    );
    animation: marker-scroll 30s linear infinite;
  }

  @keyframes marker-scroll {
    from { transform: translateY(0); }
    to { transform: translateY(-1000px); }
  }

  /* Fix: Social Icons Visibility */
  .social-links {
    display: flex;
    justify-content: center;
    gap: 25px;
    margin-top: 15px;
    position: relative;
  }

  .social-links a {
    color: #00f2ff;  /*Bright Cyan */
    font-size: 1.8rem; /* Increased size for visibility */
    transition: 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    /*filter: drop-shadow(0 0 8px rgba(0, 242, 255, 0.8));*/
    text-decoration: none;
  }

  .social-links a:hover {
    color: #ffffff;
    transform: scale(1.3);
    /*filter: drop-shadow(0 0 15px #00f2ff);*/
  }

  .social-links img {
    width: 38px; /* Adjusted size for better visibility */
    height: 38px;
  }

  /* Layout and General Styles */
  .content-wrapper {
    position: relative;
    z-index: 10;
    padding: 50px 30px;
    max-width: 1300px;
    margin: 0 auto;
    text-align: center;
  }

  .page-title {
    color: #fff;
    font-size: 2.7rem;
    /*text-transform: uppercase;*/
    letter-spacing: 5px;
    margin-bottom: 40px;
    text-shadow: 0 0 20px rgba(0, 242, 255, 0.4);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 40px;
  }

  .member-card {
    background: rgba(13, 17, 23, 0.8);
    border: 1px solid rgba(0, 242, 255, 0.3);
    border-radius: 15px;
    overflow: hidden;
    transition: 0.3s;
    backdrop-filter: blur(10px);
  }

  .member-card:hover {
    border-color: #00f2ff;
    box-shadow: 0 0 30px rgba(0, 242, 255, 0.2);
  }

  .image-box {
    height: 350px;
    border-bottom: 2px solid rgba(0, 242, 255, 0.1);
  }

  .image-box img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .info-overlay {
    padding: 25px;
  }

  .info-overlay h3 { color: white; margin: 0; font-size: 1.4rem; letter-spacing: 1px; }
  .info-overlay p { color: #888; font-size: 0.95rem; margin: 12px 0; font-style: italic; }

  /* Drifting Character */
  .character-space {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 5;
  }

  .drifting-char {
    width: 250px;
    position: absolute;
    animation: drift-away 40s linear infinite;
  }

  @keyframes drift-away {
    0% { top: 10%; left: -200px; transform: rotate(0deg); }
    100% { top: 80%; left: 110vw; transform: rotate(360deg); }
  }
</style>