  border-radius: inherit;
  z-index: -1;
}
.modal-title{
  font-size: clamp(1.6rem, 2.5vw, 2.4rem);
  font-weight:700;
  color:#ffd88a;
}
.modal-info .name{
  font-size: clamp(1.5rem, 2vw, 2rem);
  font-weight:700;
}
.modal-info .company{
  font-size: clamp(1rem, 1.5vw, 1.3rem);
  font-weight:700;
  opacity:0.85;
}
.modal-info .salary{
  font-size:1.5rem;
  font-weight:700;
  color:#ffd88a;
  letter-spacing:1px;
}
.modal-info h2,
.modal-info p{
  text-shadow:0 0 8px rgba(255,255,255,0.15);
}
@media (max-width: 768px) {
   .highlight-img{
    display:none;
  }
  .slider-btn{
    display:none;
  }
  .hero {
    height: auto;
    min-height: unset;
    padding: 2rem 0 3rem;
  }
  .slide {
    position: static !important;  
    opacity: 0;
    display: none;
  }
.modal-title{
  font-size: clamp(1.6rem, 2.5vw, 2.4rem);
  font-weight:700;
  color:#ffd88a;
}
.modal-info .name{
  font-size: clamp(1.5rem, 2vw, 2rem);
  font-weight:700;
}
.modal-info .company{
  font-size: clamp(1rem, 1.5vw, 1.3rem);
  opacity:0.85;
}
.modal-info .salary{
  font-size: clamp(1.1rem, 1.7vw, 1.5rem);
  font-weight:600;
  color:#ffd88a;
}
  .slide.active {
    display: flex;
    opacity: 1;
  }
  .slide.active {
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 1.2rem;
    padding: 1rem;
    text-align: center;
  }
  .image-box {
    width: 85vw;
    max-width: 320px;
    aspect-ratio: 1 / 1;
    order: 1;
  }
  .slide-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .scrollpagetexts-highlight {
    order: 2;
    font-size: 1.5rem;
  }
  .summary {
    order: 3;
    font-size: 0.95rem;
    line-height: 1.6;
    max-width: 95%;
  }
  .student-img {
  width: 100%;
  max-width: 260px;
  aspect-ratio: 1 / 1;   
  object-fit: cover;
  border-radius: 1.2rem;
}
  .dots {
    order: 4;
    position: relative;
    margin-top: 1rem;
  }
  .students {
  display: grid;
  grid-template-columns: repeat(
    auto-fit,
    minmax(180px, max-content)
  );
  gap: 1.5rem;
  justify-content: center;
}
.student-thumb {
  width: 100%;
  max-width: 120px;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  border-radius: 1rem;
}
  .modal-card{
    flex-direction:column;
    text-align:center;
  }
  .student-img {
    width: 70%;
    max-width: 220px;
  }
}
</style>
<script client:load>
let current = 0;
let slideTimer;
let manualOverride = false;
const slides = document.querySelectorAll(".slide");
const dotsContainer = document.querySelector(".dots");
const nextBtn = document.querySelector(".next");
const prevBtn = document.querySelector(".prev");
const hero = document.querySelector(".hero");

const yearTitle = document.querySelector(".year-title");
typeText(yearTitle, "Select the Year", 70);

const placementTitle = document.querySelector(".scrollpagetexts-highlight");
typeText(placementTitle, "Placement Highlights", 70);

slides.forEach((_, i) => {
  const dot = document.createElement("span");
  dot.className = i === 0 ? "dot active" : "dot";
  dot.onclick = () => goToSlide(i);
  dotsContainer.appendChild(dot);
});

hero.addEventListener("mouseenter", () => clearTimeout(slideTimer));
hero.addEventListener("mouseleave", startAutoSlide);

const dots = document.querySelectorAll(".dot");
function goToSlide(index){

  slides[current].classList.remove("active");
  dots[current].classList.remove("active");

  current = (index + slides.length) % slides.length;

  slides[current].classList.add("active");
  dots[current].classList.add("active");
}

nextBtn.onclick = () => {
  manualOverride = true;
  goToSlide(current + 1);
  startAutoSlide();
};

prevBtn.onclick = () => {
  manualOverride = true;
  goToSlide(current - 1);
  startAutoSlide();
};
let startX = 0;

hero.addEventListener("touchstart", e=>{
  startX = e.touches[0].clientX;
});

hero.addEventListener("touchend", e => {
  const endX = e.changedTouches[0].clientX;

  if (startX - endX > 50) {
    manualOverride = true;
    goToSlide(current + 1);
  }

  if (endX - startX > 50) {
    manualOverride = true;
    goToSlide(current - 1);
  }

  startAutoSlide();
});
function startAutoSlide() {

  clearTimeout(slideTimer);

  let delay;

  if (manualOverride) {
    delay = 7000;   
  } 
  else {
    delay = current === 0 ? 8000 : 4000;
  }

  slideTimer = setTimeout(() => {
    manualOverride = false;   
    goToSlide(current + 1);
    startAutoSlide();
  }, delay);
}
startAutoSlide();
