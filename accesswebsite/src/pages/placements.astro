const studentsSection = document.querySelector(".students");
const modal = document.querySelector(".modal");

document.querySelectorAll(".years button").forEach(btn => {
  btn.onclick = () => loadStudents(btn.dataset.year);
});

function loadStudents(year) {
  studentsSection.innerHTML = "";
  studentsSection.classList.remove("hidden");

studentsData[year]?.forEach(s => {
  const card = document.createElement("div");
  card.className = "student";

  card.innerHTML = `
    <img class="student-thumb" src="${s.img}" alt="${s.name}" />
    <h3>${s.name}</h3>
    
  `;
card.style.animationDuration = (3 + Math.random() * 3) + "s";
card.style.animationDelay = (Math.random() * 2) + "s";
  card.onclick = () => openModal(s);
  studentsSection.appendChild(card);
});
}

function openModal(s) {
  modal.classList.remove("hidden");
modal.querySelector(".name").innerHTML=``;
modal.querySelector(".company").innerHTML=``;
modal.querySelector(".modal-title").innerHTML=``;
  const nameEl = modal.querySelector(".name");
  const companyEl = modal.querySelector(".company");
const titleEl = modal.querySelector(".modal-title");
typeText(titleEl, "Congratulations ", 40);
  modal.querySelector(".student-img").src = s.img;

  typeText(nameEl, "Name: " + s.name, 60);
  
  setTimeout(() => {
    typeText(companyEl, "Placed at: " + s.company, 60);
  }, 500);

  document.body.style.overflow = "hidden";
}
function typeText(element, text, speed = 50) {
  element.textContent = "";
  let i = 0;

  function type() {
    if (i < text.length) {
      element.textContent += text[i];
      i++;
      setTimeout(type, speed);
    }
  }

  type();
}

document.querySelector(".close").onclick = () => {
  modal.classList.add("hidden");
  document.body.style.overflow = "";
};
