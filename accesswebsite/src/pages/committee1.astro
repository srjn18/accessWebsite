const years = Object.keys(committeeData);
---

<Layout>
<Navbar />

<section class="committee-page">
  <div class="year-tabs">
    {years.map((year,index)=>(
      <button class={`year-tab ${index===0?"active":""}`} data-year={year}>{year}</button>
    ))}
  </div>

  {years.map((year,index)=>(
    <div class="container" data-year={year} style={index===0?"":"display:none"}>
      <h1>ACCESS Committee Members {year}</h1>

      <div class="members-grid">
        {committeeData[year].filter(m=>!m.role.includes("CR")).map(member=>(
          <div class="member">
            <img src={`/images/Committee Members Pics/${year} Members/${member.image}`} alt={member.name} class="faculty-photo"/>
            <h2>{member.name}</h2>
            <p class="role">{member.role}</p>
            {member.semester && <p class="semester">Semester: {member.semester}</p>}
          </div>
        ))}
      </div>

      {committeeData[year].some(m=>m.role.includes("CR")) && (
        <>
          <h2 class="cr-header">Class Representatives</h2>
          <div class="members-grid">
            {committeeData[year].filter(m=>m.role.includes("CR")).map(member=>(
              <div class="member">
                <img src={`/images/Committee Members Pics/${year} Members/${member.image}`} alt={member.name} class="faculty-photo"/>
                <h2>{member.name}</h2>
                <p class="role">{member.role}</p>
                {member.semester && <p class="semester">Semester: {member.semester}</p>}
              </div>
            ))}
          </div>
        </>
      )}
    </div>
  ))}
</section>

<Footer />

<script is:inline>
const tabs=document.querySelectorAll(".year-tab");
const sections=document.querySelectorAll(".container");
tabs.forEach(tab=>{
  tab.addEventListener("click",()=>{
    tabs.forEach(t=>t.classList.remove("active"));
    tab.classList.add("active");
    const year=tab.dataset.year;
    sections.forEach(section=>{
      section.style.display = section.dataset.year===year ? "block" : "none";
    });
  });
});
</script>

<style>
.committee-page{margin-top:120px;padding:20px;}
.year-tabs{display:flex;justify-content:center;gap:20px;margin-bottom:40px;flex-wrap:wrap;}
.year-tab{padding:10px 25px;border:none;background:#111;color:#fff;border-radius:30px;cursor:pointer;}
.year-tab.active{background:#ff5e00;}
.members-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:30px;margin-bottom:40px;}
.member{background:#111;padding:20px;text-align:center;border-radius:20px;}
.member img{width:120px;height:120px;border-radius:50%;object-fit:cover;margin-bottom:15px;}
.role{color:#ff5e00;font-weight:600;}
.semester{font-size:14px;color:#ccc;}
.cr-header{text-align:center;color:#ff5e00;margin:40px 0 20px;font-size:24px;font-weight:700;}
.faculty-photo{width:120px;height:120px;border-radius:50%;object-fit:cover;}
</style>

</Layout>
